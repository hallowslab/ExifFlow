{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ExifFlow",
  "version": "0.1.0-alpha",
  "identifier": "com.exifflow.htl",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ExifFlow",
        "width": 1200,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      },
      "wix": {
        "language": ["en-US", "pt-PT"]
      }
    },
    "targets": ["deb", "rpm", "msi", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}